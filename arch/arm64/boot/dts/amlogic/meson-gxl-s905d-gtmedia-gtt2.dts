/dts-v1/;

#include "meson-gxl-s905d.dtsi"
#include "meson-gx-p23x-q20x.dtsi"

/ {
	compatible = "amlogic,gtmedia-gtt2", "amlogic,s905d", "amlogic,meson-gxl";
	model = "GTMedia GTT-2";

	i2c-display {
		compatible = "i2c-gpio";
		sda-gpios = <&gpio 72 (GPIO_ACTIVE_HIGH | GPIO_OPEN_DRAIN)>;
		scl-gpios = <&gpio 71 (GPIO_ACTIVE_HIGH | GPIO_OPEN_DRAIN)>;
		i2c-gpio,delay-us = <5>;
		#address-cells = <1>;
		#size-cells = <0>;

		display@24 {
			compatible = "fdhisi,fd650", "titanmec,tm1650";
			reg = <0x24>;

			digits {
				#address-cells = <1>;
				#size-cells = <0>;
				digit@0 {
					reg = <0>;
					segments = <3 0>,
						   <3 6>,
						   <3 4>,
						   <3 2>,
						   <3 1>,
						   <3 7>,
						   <3 5>;
				};
				digit@1 {
					reg = <1>;
					segments = <2 0>,
						   <2 6>,
						   <2 4>,
						   <2 2>,
						   <2 1>,
						   <2 7>,
						   <2 5>;
				};
				digit@2 {
					reg = <2>;
					segments = <1 0>,
						   <1 6>,
						   <1 4>,
						   <1 2>,
						   <1 1>,
						   <1 7>,
						   <1 5>;
				};
				digit@3 {
					reg = <3>;
					segments = <0 0>,
						   <0 6>,
						   <0 4>,
						   <0 2>,
						   <0 1>,
						   <0 7>,
						   <0 5>;
				};
			};

			leds {
				#address-cells = <2>;
				#size-cells = <0>;
				led@2,3 {
					reg = <2 3>;
					function = "colon";
				};
			};
		};
	};

};

&ethmac {
	phy-mode = "rmii";
	phy-handle = <&internal_phy>;
};

&sd_emmc_a {
	sdio: wifi@1 {
		reg = <1>;
	};
};

&i2c_B {
	status = "okay";
	pinctrl-0 = <&i2c_b_pins>;
	pinctrl-names = "default";
};

&cbus {
	dvb_demux: dvb@5800 {
		compatible = "amlogic,gxl-dvb";

		reg = <0x0 0x5800 0x0 0x400>,
		      <0x0 0x8c40 0x0 0x20>;
		reg-names = "ts", "async-fifo";

		interrupts = <GIC_SPI 23 IRQ_TYPE_EDGE_RISING>,
			     <GIC_SPI 5 IRQ_TYPE_EDGE_RISING>,
			     <GIC_SPI 53 IRQ_TYPE_EDGE_RISING>,
			     <GIC_SPI 19 IRQ_TYPE_EDGE_RISING>,
			     <GIC_SPI 25 IRQ_TYPE_EDGE_RISING>;
        interrupt-names = "demux0", "demux1", "demux2", "dvr0", "dvr1";

		clocks = <&clkc CLKID_DEMUX>;
		clock-names = "demux";

		#address-cells = <1>;
		#size-cells = <0>;

		pinctrl-names = "default";
		pinctrl-0 = <&dvb_p_ts0_pins>;

		amlogic,num-filters = <32>;
		ts0-control = <0>;

		tsin@0 {
			reg = <0>;
			amlogic,ts-bus-width = <8>;
			status = "okay";
		};
	};
};
